# ============================================
# Supabase Database Configuration (REQUIRED)
# ============================================
# Get these values from your Supabase project dashboard (https://supabase.com)
# 1. Go to Project Settings > API
# 2. Copy the Project URL and anon/public key
# Copy this file to .env.local and fill in your values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# SMS Gateway (httpSMS) - Optional
# ============================================
# Get these from https://httpsms.com after creating an account
# and installing the httpSMS app on your Android phone.
# HTTPSMS_API_KEY=your_httpsms_api_key_here
# HTTPSMS_PHONE_ID=your_httpsms_phone_id_here

# ============================================
# n8n Automation Webhook Secret - Optional
# ============================================
# This key is used to authenticate incoming requests from n8n workflows.
# All n8n API endpoints require this key in the X-API-Key header.
# N8N_API_KEY=sr-n8n-key-change-me
