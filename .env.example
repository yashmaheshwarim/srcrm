# SR Finance - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# SMS Gateway (httpSMS)
# ============================================
# Get these from https://httpsms.com after creating an account
# and installing the httpSMS app on your Android phone.
# HTTPSMS_API_KEY=your_httpsms_api_key_here
# HTTPSMS_PHONE_ID=your_httpsms_phone_id_here

# ============================================
# n8n Automation Webhook Secret
# ============================================
# This key is used to authenticate incoming requests from n8n workflows.
# All n8n API endpoints require this key in the X-API-Key header.
# N8N_API_KEY=sr-n8n-key-change-me

# ============================================
# Next.js Public Variables
# ============================================
# Your deployed website URL (used for webhook callbacks)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
