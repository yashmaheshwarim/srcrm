NEXT_PUBLIC_SUPABASE_URL=https://sirpwuycfueslohltmkd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNpcnB3dXljZnVlc2xvaGx0bWtkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0NzUyNjIsImV4cCI6MjA5ODA1MTI2Mn0.-uSVbwm4GGauB73ETE1LkEGFwH3oviVkVeZownG2pms


# ============================================
# n8n Automation Webhook (REQUIRED for n8n integration)
# ============================================
# This key authenticates requests from n8n workflows via the X-API-Key header.
N8N_API_KEY=sr-n8n-key-change-me

# ============================================
# SMS Gateway (httpSMS) - Optional
# ============================================
# Get these from https://httpsms.com after creating an account
# and installing the httpSMS app on your Android phone.
# HTTPSMS_API_KEY=your_httpsms_api_key_here
# HTTPSMS_PHONE_ID=your_httpsms_phone_id_here

# ============================================
# Stripe - Optional (if payment features are used)
# ============================================
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=

# ============================================
# Supabase Object Storage (S3-compatible) - REQUIRED for file uploads
# ============================================
# Get these from your Supabase project:
#   Dashboard → Storage → Settings → S3 Connection
# Or for local Supabase:
#   S3_ENDPOINT=http://localhost:8000/storage/v1/s3
#   S3_ACCESS_KEY_ID=your_access_key_id
#   S3_SECRET_ACCESS_KEY=your_secret_access_key
#   S3_BUCKET=documents
#   S3_REGION=auto
S3_ENDPOINT=https://sirpwuycfueslohltmkd.storage.supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=2d7b0d8e620e13f0678a55bd35f05b34
S3_SECRET_ACCESS_KEY=dcb08e5d3f44be768864d267629a27cf830e7f7bf0a0ae232b4ed089a688b9f3
S3_BUCKET=srstoragehouse
