# ============================================
# Supabase Database Configuration (REQUIRED)
# ============================================
# Copy this file to .env.local and fill in your values.
#
# For local development with Docker Compose, use the values below:
#   NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk1NDM1NjAwCn0.dc_X5iR_VP_pTkarTusenH1b1_VZ0YGejKCLBGp-R3A
#
# For production, replace with your actual Supabase project values:
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# n8n Automation Webhook (REQUIRED for n8n integration)
# ============================================
# This key authenticates requests from n8n workflows via the X-API-Key header.
N8N_API_KEY=sr-n8n-key-change-me

# ============================================
# SMS Gateway (httpSMS) - Optional
# ============================================
# Get these from https://httpsms.com after creating an account
# and installing the httpSMS app on your Android phone.
# HTTPSMS_API_KEY=your_httpsms_api_key_here
# HTTPSMS_PHONE_ID=your_httpsms_phone_id_here

# ============================================
# Stripe - Optional (if payment features are used)
# ============================================
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
